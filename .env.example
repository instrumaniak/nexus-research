# Nexus Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Database
# =============================================================================
DATABASE_PATH=./nexus.db

# =============================================================================
# JWT Secrets (generate with: openssl rand -hex 32)
# =============================================================================
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# =============================================================================
# AI Provider Configuration
# Supports: OpenRouter, Ollama, or any OpenAI-compatible endpoint
# =============================================================================

# For OpenRouter (default):
AI_PROVIDER_API_KEY=your_openrouter_api_key_here
AI_PROVIDER_BASE_URL=https://openrouter.ai/api/v1

# For Ollama (local/self-hosted):
# AI_PROVIDER_API_KEY=ollama  # or leave blank
# AI_PROVIDER_BASE_URL=http://localhost:11434/v1

# Model IDs (optional - defaults shown below)
# AI_MODEL_ORCHESTRATION=deepseek/deepseek-r1:free
# AI_MODEL_SUMMARIZATION=meta-llama/llama-3.3-70b-instruct:free
# AI_MODEL_QUICK_QA=google/gemma-2-9b-it:free
# AI_MODEL_REPORT=mistralai/mistral-7b-instruct:free

# =============================================================================
# Search API (optional - DuckDuckGo fallback works without this)
# =============================================================================
BRAVE_SEARCH_API_KEY=your_brave_api_key_here

# =============================================================================
# Server Configuration
# =============================================================================
NODE_ENV=development
PORT=3000

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=info
LOG_RETENTION_DAYS=30

# =============================================================================
# Email (Phase 2 - cPanel SMTP)
# =============================================================================
# SMTP_HOST=mail.raziur.com
# SMTP_PORT=587
# SMTP_USER=noreply@raziur.com
# SMTP_PASS=your_smtp_password
# SMTP_FROM=Nexus <noreply@raziur.com>

# =============================================================================
# OAuth (Phase 4 - Google Sign-In)
# =============================================================================
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_CALLBACK_URL=https://raziur.com/api/auth/google/callback
